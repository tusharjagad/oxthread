# OxThread Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/oxthread"

# ─── Auth & Sessions ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-super-secret-key-at-least-32-chars"
JWT_SECRET="your-jwt-secret-at-least-32-chars"
SESSION_EXPIRY_MINUTES=30

# ─── Azure ────────────────────────────────────────────────────────────────────
AZURE_CLIENT_ID="your-azure-client-id"
AZURE_CLIENT_SECRET="your-azure-client-secret"
AZURE_TENANT_ID="your-azure-tenant-id"
AZURE_SUBSCRIPTION_ID="your-azure-subscription-id"
AZURE_KEY_VAULT_URL="https://your-keyvault.vault.azure.net"

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN="your-github-personal-access-token"
GITHUB_ORG="your-github-org"

# ─── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ─── Email (for invitations) ──────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@oxthread.io"

# ─── Seed Admin ───────────────────────────────────────────────────────────────
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="Admin@12345!"

# ─── Scheduler ────────────────────────────────────────────────
SCHEDULER_API_KEY="your-scheduler-api-key"

# ─── PostgreSQL Secret References ─────────────────────────────
# Each registered server references an env var by name.
# Format: postgresql://user:password@host:port/database
# PROD_DB_URL="postgresql://admin:pass@prod-host:5432/mydb"
